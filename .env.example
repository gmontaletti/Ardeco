# PostgreSQL connection
PG_HOST=your-postgres.example.com
PG_PORT=5432
PG_DBNAME=ardeco
PG_USER=ardeco_writer
PG_PASSWORD=change-me
PG_SCHEMA=ardeco

# ARDECO download parameters (defaults shown)
ARDECO_NUTSCODE=ITC4
ARDECO_LEVEL=2,3
ARDECO_VERSION=2024
ARDECO_STAGING_PATH=/tmp/ardeco_staging.duckdb
ARDECO_DOWNLOAD_TIMEOUT=300
