ensure_unique(ruwcd_itc4)
latest_ruwcd <- ruwcd_itc4[YEAR == max(YEAR)]

list(
  icon  = "wallet2",
  color = "primary",
  value = format(round(latest_ruwcd$VALUE[1]), big.mark = ",")
)
```

