---
title: "ARDECO Lombardia"
format:
  dashboard:
    orientation: rows
    nav-buttons: [github]
    theme: cosmo
include-after-body: R/plotly-resize.html
---

```{css}
#| echo: false
.bslib-value-box .value-box-grid {
  overflow: visible !important;
}
```

```{r}
#| label: setup
#| include: false

source("R/helpers.R")

# 1. Labels and geography -----

labels <- load_labels()
geo    <- load_geo()
```

# Popolazione e demografia

```{r}
#| label: pop-load
#| include: false

# 1. Load all population variables once -----

snptd <- load_variable("SNPTD")
snptn <- load_variable("SNPTN")
snpbn <- load_variable("SNPBN")
snpdn <- load_variable("SNPDN")
snpnn <- load_variable("SNPNN")
snmtn <- load_variable("SNMTN")
snpcn <- load_variable("SNPCN")
```

## Row {height="100px"}

```{r}
#| label: pop-vb1
#| content: valuebox
#| title: "Popolazione totale (Lombardia)"

# 1. Value box: SNPTD, ITC4, latest year -----

snptd_itc4 <- filter_data(snptd[NUTSCODE == "ITC4"], unit = "NR")
ensure_unique(snptd_itc4)
latest_snptd <- snptd_itc4[YEAR == max(YEAR)]

list(
  icon  = "people-fill",
  color = "primary",
  value = format(round(latest_snptd$VALUE[1]), big.mark = ",")
)
```

```{r}
#| label: pop-vb2
#| content: valuebox
#| title: "Variazione popolazione (Lombardia)"

# 2. Value box: SNPCN growth rate, ITC4, latest year -----

snpcn_itc4 <- filter_data(snpcn[NUTSCODE == "ITC4"], unit = "GROWRT",
                           sex = "TOTAL", age = "TOTAL")
ensure_unique(snpcn_itc4)
latest_snpcn <- snpcn_itc4[YEAR == max(YEAR)]

list(
  icon  = "graph-up-arrow",
  color = "info",
  value = paste0(round(latest_snpcn$VALUE[1], 2), "%")
)
```

## Row

### Column {width="60%"}

::: {.panel-tabset}

#### Popolazione media annua

```{r}
#| label: pop-ts-snptd

# 1. SNPTD — single unit NR, no SEX/AGE breakdown -----

snptd_filt <- filter_data(snptd, unit = "NR")
ensure_unique(snptd_filt)
ts_plotly_regional(
  snptd_filt,
  var_label  = get_var_label("SNPTD", labels),
  unit_label = get_unit_label("NR", labels)
)
```

#### Popolazione per sesso ed età

```{r}
#| label: pop-ts-snptn

# 2. SNPTN — nested tabs by SEX -----
```

::: {.panel-tabset}

##### Totale

```{r}
#| label: pop-ts-snptn-tot

snptn_tot <- filter_data(snptn, unit = "NR", sex = "TOTAL", age = "TOTAL")
ensure_unique(snptn_tot)
ts_plotly_regional(
  snptn_tot,
  var_label  = get_var_label("SNPTN", labels),
  unit_label = get_unit_label("NR", labels)
)
```

##### Femmine

```{r}
#| label: pop-ts-snptn-f

snptn_f <- filter_data(snptn, unit = "NR", sex = "F", age = "TOTAL")
ensure_unique(snptn_f)
ts_plotly_regional(
  snptn_f,
  var_label  = paste0(get_var_label("SNPTN", labels), " — Femmine"),
  unit_label = get_unit_label("NR", labels)
)
```

##### Maschi

```{r}
#| label: pop-ts-snptn-m

snptn_m <- filter_data(snptn, unit = "NR", sex = "M", age = "TOTAL")
ensure_unique(snptn_m)
ts_plotly_regional(
  snptn_m,
  var_label  = paste0(get_var_label("SNPTN", labels), " — Maschi"),
  unit_label = get_unit_label("NR", labels)
)
```

:::

