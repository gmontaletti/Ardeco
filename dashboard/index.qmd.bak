### Column {width="40%"}

```{r}
#| label: pop-map

# Map: SNPTD flagship -----

snptd_map <- filter_data(snptd, unit = "NR")
map_leaflet(
  snptd_map,
  geo        = geo,
  var_label  = get_var_label("SNPTD", labels),
  unit_label = get_unit_label("NR", labels)
)
```

## Row {height="30%"}

```{r}
#| label: pop-table

# Table: SNPTD -----

snptd_tbl <- filter_data(snptd, unit = "NR")
summary_dt(
  snptd_tbl,
  var_label  = get_var_label("SNPTD", labels),
  unit_label = get_unit_label("NR", labels)
)
```

# Mercato del lavoro

```{r}
#| label: lab-load
#| include: false

# 1. Load all labour market variables once -----

snetd <- load_variable("SNETD")
snwtd <- load_variable("SNWTD")
rnecn <- load_variable("RNECN")
rnutn <- load_variable("RNUTN")
rnlcn <- load_variable("RNLCN")
rnlht <- load_variable("RNLHT")
```

## Row {height="100px"}

```{r}
#| label: lab-vb1
#| content: valuebox
#| title: "Tasso di occupazione (Lombardia)"

# 1. Value box: RNECN, ITC4, latest year -----

rnecn_itc4 <- filter_data(rnecn[NUTSCODE == "ITC4"], age = "Y20-64")
ensure_unique(rnecn_itc4)
latest_rnecn <- rnecn_itc4[YEAR == max(YEAR)]

list(
  icon  = "briefcase-fill",
  color = "success",
  value = paste0(round(latest_rnecn$VALUE[1], 1), "%")
)
```

```{r}
#| label: lab-vb2
#| content: valuebox
#| title: "Tasso di disoccupazione (Lombardia)"

# 2. Value box: RNUTN, ITC4, latest year -----

rnutn_itc4 <- filter_data(rnutn[NUTSCODE == "ITC4"])
ensure_unique(rnutn_itc4)
latest_rnutn <- rnutn_itc4[YEAR == max(YEAR)]

list(
  icon  = "person-x-fill",
  color = "warning",
  value = paste0(round(latest_rnutn$VALUE[1], 1), "%")
)
```

## Row

### Column {width="60%"}

::: {.panel-tabset}

#### Occupazione workplace-based

```{r}
#| label: lab-ts-snetd

# 1. SNETD -----

snetd_filt <- filter_data(snetd, unit = "THS")
ensure_unique(snetd_filt)
ts_plotly_regional(
  snetd_filt,
  var_label  = get_var_label("SNETD", labels),
  unit_label = get_unit_label("THS", labels)
)
```

#### Dipendenti workplace-based

```{r}
#| label: lab-ts-snwtd

# 2. SNWTD -----

snwtd_filt <- filter_data(snwtd, unit = "THS")
ensure_unique(snwtd_filt)
ts_plotly_regional(
  snwtd_filt,
  var_label  = get_var_label("SNWTD", labels),
  unit_label = get_unit_label("THS", labels)
)
```

#### Tasso di occupazione

```{r}
#| label: lab-ts-rnecn

# 3. RNECN — filter to age 20-64 (standard employment rate) -----

rnecn_filt <- filter_data(rnecn, age = "Y20-64")
ensure_unique(rnecn_filt)
ts_plotly_regional(
  rnecn_filt,
  var_label  = get_var_label("RNECN", labels),
  unit_label = get_unit_label(rnecn_filt$UNIT[1], labels)
)
```

#### Tasso di disoccupazione

```{r}
#| label: lab-ts-rnutn

# 4. RNUTN — single unit -----

rnutn_filt <- filter_data(rnutn)
ensure_unique(rnutn_filt)
ts_plotly_regional(
  rnutn_filt,
  var_label  = get_var_label("RNUTN", labels),
  unit_label = get_unit_label(rnutn_filt$UNIT[1], labels)
)
```

#### Forza lavoro

```{r}
#| label: lab-ts-rnlcn

# 5. RNLCN — single unit -----

