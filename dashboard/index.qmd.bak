# Occupazione per settore

```{r}
#| label: sec-load
#| include: false

# 1. Load sector-disaggregated variables once -----

snetz <- load_variable("SNETZ")
rnlhz <- load_variable("RNLHZ")
```

## Row {height="100px"}

```{r}
#| label: sec-vb1
#| content: valuebox
#| title: "Settori NACE disponibili"

# 1. Count unique non-NA sectors in SNETZ -----

n_sectors <- length(unique(snetz[!is.na(SECTOR), SECTOR]))

list(
  icon  = "building",
  color = "primary",
  value = as.character(n_sectors)
)
```

```{r}
#| label: sec-vb2
#| content: valuebox
#| title: "Ultimo anno disponibile"

# 2. Max year in SNETZ -----

list(
  icon  = "calendar-check",
  color = "info",
  value = as.character(max(snetz$YEAR, na.rm = TRUE))
)
```

## Row

### Column {width="60%"}

::: {.panel-tabset}

#### Occupazione per settore NACE

```{r}
#| label: sec-ts-snetz

# 1. SNETZ sector chart — keep all non-NA sectors -----

snetz_sec <- snetz[!is.na(SECTOR)]
ts_plotly_by_sector(
  snetz_sec,
  var_label  = get_var_label("SNETZ", labels),
  unit_label = get_unit_label("THS", labels),
  labels     = labels
)
```

#### Ore lavorate per settore NACE

```{r}
#| label: sec-ts-rnlhz

# 2. RNLHZ sector chart — keep all non-NA sectors -----

rnlhz_sec <- rnlhz[!is.na(SECTOR)]
ts_plotly_by_sector(
  rnlhz_sec,
  var_label  = get_var_label("RNLHZ", labels),
  unit_label = get_unit_label("THS", labels),
  labels     = labels
)
```

:::

### Column {width="40%"}

```{r}
#| label: sec-map

# Map: SNETZ sector O-U (total economy) -----

snetz_map <- filter_data(snetz[SECTOR == "O-U"])
map_leaflet(
  snetz_map,
  geo        = geo,
  var_label  = get_var_label("SNETZ", labels),
  unit_label = get_unit_label("THS", labels)
)
```

## Row {height="30%"}

```{r}
#| label: sec-table

# Table: SNETZ sector O-U -----

snetz_tbl <- filter_data(snetz[SECTOR == "O-U"])
summary_dt(
  snetz_tbl,
  var_label  = get_var_label("SNETZ", labels),
  unit_label = get_unit_label("THS", labels)
)
```

# PIL e valore aggiunto

```{r}
#| label: gdp-load
#| include: false

# 1. Load GDP and value-added variables once -----

suvgd <- load_variable("SUVGD")
sovgd <- load_variable("SOVGD")
suvge <- load_variable("SUVGE")
sovge <- load_variable("SOVGE")
suvgz <- load_variable("SUVGZ")
sovgz <- load_variable("SOVGZ")
```

## Row {height="100px"}

```{r}
#| label: gdp-vb1
#| content: valuebox
#| title: "PIL corrente (Lombardia)"

# 1. Value box: SUVGD MIO_EUR, ITC4, latest year -----

suvgd_itc4 <- filter_data(suvgd[NUTSCODE == "ITC4"],
                           unit = "MIO_EUR")
ensure_unique(suvgd_itc4)
latest_suvgd <- suvgd_itc4[YEAR == max(YEAR)]

list(
  icon  = "currency-euro",
  color = "success",
  value = format(round(latest_suvgd$VALUE[1]), big.mark = ",")
)
```

```{r}
#| label: gdp-vb2
#| content: valuebox
#| title: "PIL costante (Lombardia)"

# 2. Value box: SOVGD MIO_EUR2015, ITC4, latest year -----

sovgd_itc4 <- filter_data(sovgd[NUTSCODE == "ITC4"],
                           unit = "MIO_EUR2015")
ensure_unique(sovgd_itc4)
latest_sovgd <- sovgd_itc4[YEAR == max(YEAR)]

list(
  icon  = "bar-chart-fill",
  color = "info",
  value = format(round(latest_sovgd$VALUE[1]), big.mark = ",")
)
```

## Row

### Column {width="60%"}

::: {.panel-tabset}

#### PIL a prezzi correnti

