# Formazione del capitale

```{r}
#| label: cap-load
#| include: false

# 1. Load capital formation variables once -----

ruigt <- load_variable("RUIGT")
roigt <- load_variable("ROIGT")
ruigz <- load_variable("RUIGZ")
roigz <- load_variable("ROIGZ")
```

## Row {height="100px"}

```{r}
#| label: cap-vb1
#| content: valuebox
#| title: "FBCF corrente (Lombardia)"

# 1. Value box: RUIGT MIO_EUR, ITC4, latest year -----

ruigt_itc4 <- filter_data(ruigt[NUTSCODE == "ITC4"],
                           unit = "MIO_EUR")
ensure_unique(ruigt_itc4)
latest_ruigt <- ruigt_itc4[YEAR == max(YEAR)]

list(
  icon  = "hammer",
  color = "success",
  value = format(round(latest_ruigt$VALUE[1]), big.mark = ",")
)
```

